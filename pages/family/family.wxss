/* pages/family/family.wxss */
.family-page {
  background-color: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 100rpx;
}

.family-container {
  height: calc(100vh - 60px);
  padding: 15px;
}

.family-info {
  position: relative;
  height: 150px;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 20px;
}

.family-banner {
  width: 100%;
  height: 100%;
}

.family-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.family-slogan {
  color: white;
  font-size: 18px;
  font-weight: bold;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
}

.family-list {
  background: white;
  border-radius: 12px;
  padding: 10px;
  margin-bottom: 20px;
}

.family-member {
  display: flex;
  padding: 15px 10px;
  border-bottom: 1px solid #f0f0f0;
}

.family-member:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  margin-right: 15px;
}

.member-info {
  flex: 1;
}

.member-name-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 5px;
}

.member-name {
  font-size: 16px;
  font-weight: bold;
  margin-right: 8px;
}

.member-age {
  color: #999;
  font-size: 14px;
  margin-right: 5px;
}

.member-relation {
  color: #19be6b;
  font-size: 13px;
}

.member-status {
  font-size: 12px;
  color: #666;
}

.member-actions {
  display: flex;
  align-items: center;
}

.call-btn, .message-btn {
  background: none;
  padding: 5px;
  margin-left: 8px;
}

.action-icon {
  width: 24px;
  height: 24px;
}

.health-dynamics {
  background: white;
  border-radius: 12px;
  padding: 15px;
}

.health-event {
  display: flex;
  padding: 12px 0;
  border-bottom: 1px solid #eee;
}

.health-event:last-child {
  border-bottom: none;
}

.event-icon {
  width: 32px;
  height: 32px;
  margin-right: 15px;
  align-self: center;
}

.event-content {
  flex: 1;
}

.event-title {
  font-size: 14px;
  margin-bottom: 5px;
}

.event-desc {
  font-size: 12px;
  color: #666;
}

.event-time {
  font-size: 12px;
  color: #999;
  align-self: center;
}

.add-member-modal .modal-content {
  padding: 15px;
}

.input-group {
  margin-bottom: 15px;
}

.input-label {
  display: block;
  margin-bottom: 5px;
  font-size: 14px;
}

input {
  height: 40px;
  border-bottom: 1px solid #eee;
  padding: 5px 0;
}

.picker {
  display: flex;
  justify-content: space-between;
  height: 40px;
  padding: 10px 0;
  border-bottom: 1px solid #eee;
}

.arrow-down {
  width: 16px;
  height: 16px;
}