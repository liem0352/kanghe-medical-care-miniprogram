<!--pages/service/service.wxml-->
<view class="service-page">
  <!-- 服务分类导航 -->
  <scroll-view scroll-x="true" class="category-nav">
    <view class="category-item {{currentCategory === 'all' ? 'active' : ''}}" bindtap="changeCategory" data-category="all">全部</view>
    <view class="category-item {{currentCategory === 'emergency' ? 'active' : ''}}" bindtap="changeCategory" data-category="emergency">紧急</view>
    <view class="category-item {{currentCategory === 'daily' ? 'active' : ''}}" bindtap="changeCategory" data-category="daily">日常</view>
    <view class="category-item {{currentCategory === 'health' ? 'active' : ''}}" bindtap="changeCategory" data-category="health">健康</view>
    <view class="category-item {{currentCategory === 'special' ? 'active' : ''}}" bindtap="changeCategory" data-category="special">特色</view>
  </scroll-view>

  <!-- 服务网格 -->
  <view class="service-container">
    <view class="service-grid">
      <block wx:for="{{filteredServices}}" wx:key="type">
        <view class="service-item" bindtap="requestService" data-type="{{item.type}}">
          <text class="service-icon-large {{item.emoji}}">{{item.emoji}}</text>
          <text class="service-title-large">{{item.title}}</text>
        </view>
      </block>
    </view>
  </view>

  <!-- 服务资源地图 -->
  <view class="map-container">
    <view class="map-content">
      <block wx:for="{{resources}}" wx:key="id">
        <view class="resource-item" style="top: {{item.top}}%; left: {{item.left}}%">
          <text class="resource-dot-large {{item.type}}">{{item.emoji}}</text>
          <text class="resource-label-large">{{item.name}}</text>
        </view>
      </block>
      <text class="location-dot">📍</text>
      <text class="location-label">我的位置</text>
    </view>
  </view>

  <!-- 健康资讯 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">健康资讯</text>
      <text class="section-more" bindtap="viewMoreNews">更多</text>
    </view>
    <view class="news-container">
      <block wx:for="{{healthNews}}" wx:key="id">
        <view class="news-item">
          <text class="news-emoji-large">{{item.emoji}}</text>
          <view class="news-content">
            <text class="news-title-large">{{item.title}}</text>
            <text class="news-desc-large">{{item.desc}}</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 服务记录 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">服务记录</text>
      <picker bindchange="filterHistory" value="{{historyFilter}}" range="{{['全部', '进行中', '已完成']}}">
        <view class="filter-btn">{{['全部', '进行中', '已完成'][historyFilter]}}</view>
      </picker>
    </view>
    <view class="service-history">
      <block wx:for="{{filteredHistory}}" wx:key="id">
        <view class="history-item">
          <view class="history-header">
            <text class="service-type">{{item.type}}</text>
            <text class="service-date">{{item.date}}</text>
          </view>
          <view class="history-content">
            <text class="service-personnel">{{item.provider}}</text>
            <text class="service-status {{item.statusClass}}">{{item.status}}</text>
          </view>
          <view class="history-footer">
            <text>费用: {{item.cost}}</text>
            <text bindtap="viewHistoryDetail" data-id="{{item.id}}" class="view-detail">查看详情</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <!-- 服务请求模态框 -->
  <modal class="service-modal" hidden="{{!showServiceModal}}" bindcancel="closeServiceModal">
    <view slot="title">{{currentService.title}}服务</view>
    <view slot="content">
      <view class="modal-content">
        <view class="modal-row">
          <text class="modal-label">服务地址</text>
          <text class="modal-value">肇庆市端州区星湖大道78号</text>
        </view>
        <view class="modal-row">
          <text class="modal-label">预计费用</text>
          <text class="modal-value">{{currentService.price}}</text>
        </view>
        <view class="modal-row">
          <text class="modal-label">预计时间</text>
          <text class="modal-value">{{currentService.time}}</text>
        </view>
        <view class="modal-row">
          <text class="modal-label">服务说明</text>
          <text class="modal-value">{{currentService.desc}}</text>
        </view>
      </view>
    </view>
    <view slot="footer">
      <button class="btn-cancel-large" bindtap="closeServiceModal">取消</button>
      <button class="btn-confirm-large" bindtap="confirmService">确认预约</button>
    </view>
  </modal>
</view> 
