/* 适老化全局样式 */
page {
  background-color: #f8f9fa;
  color: #333;
  font-size: 32rpx; /* 增大基础字体 */
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding-bottom: 40rpx;
  line-height: 1.6; /* 增加行高 */
}

/* 增大所有文本元素 */
text, button {
  font-size: 32rpx !important;
}

/* 增强对比度 */
.section-title, .overview-title, .trend-title, .modal-title {
  color: #000 !important;
  font-weight: bold;
}

/* 增大按钮点击区域 */
button {
  min-width: 200rpx;
  min-height: 80rpx;
  padding: 20rpx 30rpx !important;
  font-size: 32rpx !important;
}

/* 头部样式（优化边距） */
/* 头部样式 - 高级版 */
.header {
  background: linear-gradient(120deg, #19be6b, #1a6d3b);
  padding: 40rpx 30rpx;
  border-radius: 30rpx;
  color: white;
  margin: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(25, 190, 107, 0.2);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.header::before {
  content: "";
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  z-index: 0;
}

.header::after {
  content: "";
  position: absolute;
  bottom: -150rpx;
  left: -50rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  z-index: 0;
}

.user-area {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 30rpx;
}

.user-info {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  box-shadow: 
    0 4rpx 20rpx rgba(0, 0, 0, 0.15),
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.3);
}

.user-avatar::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    135deg, 
    rgba(255,255,255,0.2) 0%,
    rgba(255,255,255,0) 50%,
    rgba(0,0,0,0.05) 100%
  );
  z-index: 1;
  pointer-events: none;
}

.user-avatar::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 80%;
  height: 80%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  background: radial-gradient(
    circle, 
    rgba(255,255,255,0.4) 0%,
    rgba(255,255,255,0) 70%
  );
  z-index: 2;
  pointer-events: none;
}

.user-text {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.welcome-text {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 4rpx;
  font-weight: 300;
}

.user-name {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  line-height: 1.2;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.health-score-container {
  display: inline-flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
}

.health-score-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-right: 8rpx;
  font-weight: 400;
}

.health-score {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.score-unit {
  font-size: 22rpx;
  margin-left: 2rpx;
  opacity: 0.9;
}

.weather-info {
  background: rgba(255, 255, 255, 0.15);
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  margin-left: auto;
  margin-top: 10rpx;
}

.weather-icon {
  font-size: 40rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.weather-details {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  min-width: 90rpx;
}

.weather-city {
  font-size: 22rpx;
  opacity: 0.85;
  margin-bottom: 2rpx;
}

.weather-temp {
  font-size: 30rpx;
  font-weight: 600;
}


/* 健康概览卡片（优化边距） */
.health-overview {
  background: white;
  border-radius: 30rpx;
  padding: 45rpx 40rpx; /* 增加内边距 */
  margin: 0 30rpx 30rpx; /* 增加底部外边距 */
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 35rpx; /* 增加标题与内容的间距 */
}

.overview-title {
  font-size: 38rpx; /* 增大标题字体 */
  font-weight: 600;
  color: #333;
}

.update-time {
  font-size: 28rpx;
  color: #888;
}

.vitals-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2vw; /* 增加卡片间距 */
  margin-bottom: 45rpx; /* 增加网格与趋势图的间距 */
}

.vital-item {
  background: #f1f9f4;
  border-radius: 25rpx; /* 增大圆角 */
  padding: 25rpx 15rpx; /* 增加内边距 */
  text-align: center;
  transition: all 0.3s ease;
}

.vital-item:active {
  transform: scale(0.98);
  background: #e4f5ed;
}

.vital-value {
  font-size: 44rpx; /* 增大数值字体 */
  font-weight: 600;
  margin-bottom: 12rpx; /* 增加数值与标签的间距 */
  display: block;
}

.vital-label {
  font-size: 28rpx;
  color: #666;
}

.trend-card {
  background: #f1f9f4;
  border-radius: 25rpx;
  padding: 25rpx;
  margin-top: 25rpx;
}

.trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.trend-title {
  font-size: 32rpx; /* 增大标题字体 */
  font-weight: 500;
  color: #333;
}

.view-all {
  color: #19be6b;
  font-size: 28rpx;
}

.chart-container {
  width: 100%;
  height: 280rpx;
  position: relative;
}

.health-chart {
  width: 100% !important;
  height: 100% !important;
}

/* 功能区域（优化边距） */
.services-section {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.services-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx; /* 增加标题与内容的间距 */
}

.section-title {
  font-size: 38rpx; /* 增大标题字体 */
  font-weight: 600;
  color: #333;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2vw; /* 增加服务项间距 */
}

.service-item {
  text-align: center;
  transition: all 0.3s ease;
  padding: 10rpx; /* 增加内边距 */
}

.service-item:active {
  transform: scale(0.95);
}

.service-icon {
  width: 110rpx; /* 增大图标容器 */
  height: 110rpx;
  background: #f1f9f4;
  border-radius: 30rpx; /* 增大圆角 */
  margin: 0 auto 25rpx; /* 增加底部间距 */
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  line-height: 1;
}

.service-name {
  font-size: 30rpx; /* 增大服务名称字体 */
  color: #555;
}

/* 提醒卡片（优化边距） */
.reminders-section {
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.reminder-header-actions {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx; /* 增加标题与列表的间距 */
}

.add-reminder {
  color: #19be6b;
  font-size: 30rpx;
  background: rgba(25, 190, 107, 0.1);
  padding: 10rpx 20rpx; /* 增加内边距 */
  border-radius: 30rpx;
  margin-right: 25rpx; /* 增加与查看全部的间距 */
}

.view-all {
  color: #19be6b;
  font-size: 30rpx;
}

.reminder-list {
  margin-top: 25rpx;
}

.reminder-item {
  display: flex;
  align-items: center;
  padding: 30rpx 35rpx; /* 增加内边距 */
  border-radius: 25rpx; /* 增大圆角 */
  margin-bottom: 25rpx; /* 增加项间距 */
  background: #f1f9f4;
  min-height: 140rpx; /* 增加最小高度 */
}

.reminder-icon {
  width: 90rpx; /* 增大图标容器 */
  height: 90rpx;
  border-radius: 20rpx;
  background: #d9f0e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 30rpx; /* 增加与内容的间距 */
  flex-shrink: 0;
}

.medication .reminder-icon {
  background: #f0e8ff;
}

.appointment .reminder-icon {
  background: #fff0ed;
}

.reminder-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.reminder-title {
  font-weight: 500;
  margin-bottom: 12rpx; /* 增加标题与时间的间距 */
  font-size: 32rpx; /* 增大标题字体 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.reminder-time {
  font-size: 28rpx;
  color: #666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

.reminder-action {
  background: #19be6b;
  color: white;
  border: none;
  padding: 15rpx 30rpx; /* 增加内边距 */
  border-radius: 40rpx;
  font-size: 30rpx;
  min-width: 120rpx; /* 增大按钮宽度 */
  height: 70rpx; /* 增大按钮高度 */
  line-height: 70rpx;
  margin-left: 30rpx; /* 增加与内容的间距 */
  flex-shrink: 0;
}

.reminder-action.recorded {
  background: #ccc;
}

/* 紧急求助按钮 */
.emergency-btn {
  position: fixed;
  bottom: 50rpx; /* 调整底部间距 */
  right: 50rpx; /* 调整右侧间距 */
  width: 130rpx; /* 增大按钮尺寸 */
  height: 130rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff5252, #ed3f14);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99;
  box-shadow: 0 10rpx 40rpx rgba(237, 63, 20, 0.4);
}

.sos-icon {
  font-size: 70rpx; /* 增大图标字体 */
  line-height: 1;
}

/* 紧急求助对话框 */
.emergency-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 40rpx;
  width: 80%;
  padding: 70rpx; /* 增加内边距 */
  text-align: center;
  animation: modalAppear 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.emergency-icon {
  font-size: 160rpx; /* 进一步增大图标尺寸 */
  line-height: 1;
  margin: 0 auto 40rpx; /* 调整间距 */
  display: block;
  text-align: center;
  color: #ff5252; /* 添加红色强调 */
}

.modal-title {
  font-size: 48rpx; /* 增大标题字体 */
  font-weight: 600;
  margin-bottom: 30rpx; /* 增加与正文的间距 */
}

.modal-text {
  color: #666;
  margin-bottom: 60rpx; /* 增加与按钮的间距 */
  line-height: 1.6;
  font-size: 32rpx; /* 增大正文字体 */
}

.action-buttons {
  display: flex;
  gap: 2vw; /* 增加按钮间距 */
}

.modal-btn {
  flex: 1;
  padding: 30rpx; /* 增加内边距 */
  border-radius: 40rpx; /* 增大圆角 */
  border: none;
  font-weight: 500;
  font-size: 36rpx; /* 增大按钮字体 */
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.btn-confirm {
  background: #ff5252;
  color: white;
}

/* 添加提醒对话框 */
.add-reminder-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  border-radius: 40rpx;
  width: 80%;
  padding: 70rpx; /* 增加内边距 */
  text-align: center;
  animation: modalAppear 0.3s ease-out;
}

.form-group {
  margin-bottom: 40rpx; /* 增加表单项间距 */
}

.form-label {
  display: block;
  text-align: left;
  margin-bottom: 15rpx; /* 增加标签与输入的间距 */
  font-size: 32rpx; /* 增大标签字体 */
  color: #333;
}

.form-picker, .form-input {
  background: #f8f9fa;
  border-radius: 20rpx; /* 增大圆角 */
  padding: 30rpx; /* 增加内边距 */
  width: 100%;
  box-sizing: border-box;
  font-size: 32rpx; /* 增大输入字体 */
}

.form-buttons {
  display: flex;
  gap: 30rpx; /* 增加按钮间距 */
  margin-top: 50rpx; /* 增加顶部间距 */
}

@keyframes modalAppear {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}